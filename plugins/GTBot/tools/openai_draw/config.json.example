{
  "enabled": true,
  "base_url": "https://api.openai.com/v1",
  "api_key": "",
  "model": "gpt-image-2",
  "timeout_sec": 120.0,
  "worker_concurrency": 1,
  "max_queue_size": 10,
  "default_size": "1024x1024",
  "max_width": 3840,
  "max_height": 3840,
  "size_multiple": 16,
  "max_aspect_ratio": 3.0,
  "min_pixels": 655360,
  "max_pixels": 8294400,
  "default_quality": "auto",
  "default_background": "auto",
  "default_output_format": "png",
  "download_dir": "./data/openai_draw/images",
  "max_input_image_bytes": 20971520,
  "max_input_image_count": 16,
  "command_prefix": "绘图",
  "permissions": {
    "submit": "all",
    "query": "all"
  },
  "usage_limits": {
    "enabled": false,
    "exempt_user_ids": [],
    "global_limits": {
      "per_day": 0,
      "per_week": 0
    },
    "user_limits": {
      "per_hour": 0,
      "per_day": 0,
      "per_week": 0,
      "per_month": 0
    }
  },
  "allow_compat_mode": true
}
