{
  "auto_init": true,
  "container": {
    "qdrant_server_url": "http://localhost:6333/",
    "qdrant_api_key": "",
    "qdrant_collection_name": "long_memory",
    "embed_service_type": "openai",
    "embed_service_url": "http://localhost:30020/v1/embeddings",
    "embed_model": "qwen3-embedding-0.6b",
    "embed_api_key": "",
    "notepad_max_length": 20,
    "max_sessions": 1000,
    "session_timeout_seconds": 3600.0
  },
  "rerank": {
    "enable": false,
    "service_url": "http://localhost:30021/rerank",
    "api_key": null
  },
  "recall": {
    "context_capacity": 80,
    "query_max_messages": 12,
    "query_max_chars": 800,
    "refresh_message_threshold": 3,
    "idle_refresh_seconds": 2.0,
    "max_concurrent_refreshes": 3,
    "event_log_max_items": 2,
    "event_log_total_chars": 300,
    "event_log_min_similarity": null,
    "public_knowledge_max_items": 10,
    "public_knowledge_total_chars": 200,
    "public_knowledge_min_similarity": null,
    "user_profile_max_items": 10,
    "user_profile_total_chars": 300,
    "user_profile_min_similarity": null,
    "group_profile_max_items": 5,
    "group_profile_total_chars": 300,
    "group_profile_min_similarity": null,
    "group_profile_stable_max_items": 5,
    "group_profile_stable_total_chars": 300
  },
  "ingest": {
    "processed_capacity": 200,
    "pending_capacity": 200,
    "flush_pending_threshold": 20,
    "idle_flush_seconds": 60.0,
    "flush_max_messages": 20,
    "max_concurrent_flushes": 2,
    "query_max_chars": 300,
    "message_max_chars_per_item": 200,
    "message_total_chars": 1600,
    "prefetch_total_chars": 1200,
    "provider_type": "openai_compatible",
    "model_id": "",
    "base_url": "",
    "api_key": "",
    "model_parameters": {
      "temperature": 0.2,
      "top_p": 0.95,
      "max_tokens": 1024
    },
    "public_knowledge_similarity_threshold": 0.0,
    "public_knowledge_max_items": 5,
    "public_knowledge_llm_max_items": 2,
    "public_knowledge_llm_max_chars": 180,
    "event_log_similarity_threshold": 0.0,
    "event_log_max_items": 5,
    "event_log_llm_max_items": 2,
    "event_log_llm_max_chars": 260,
    "user_profile_similarity_threshold": 0.0,
    "user_profile_max_items": 10,
    "user_profile_llm_max_items": 4,
    "user_profile_llm_max_chars": 260,
    "group_profile_min_items_threshold": 0,
    "group_profile_max_items": 20,
    "group_profile_hits_llm_max_items": 4,
    "group_profile_hits_llm_max_chars": 260,
    "group_profile_stable_llm_max_items": 4,
    "group_profile_stable_llm_max_chars": 260
  },
  "memory_editor": {
    "enable": true,
    "history_max_messages": 24,
    "max_tool_calls_per_turn": 12,
    "forward_max_total_chars": 9000,
    "forward_max_chunk_chars": 700,
    "llm": {
      "provider_type": "",
      "model_id": "",
      "base_url": "",
      "api_key": "",
      "model_parameters": {}
    }
  },
  "post_llm_ingest": {
    "recent_n": 20,
    "delay_seconds": 0.3
  },
  "cleanup": {
    "min_interval_seconds": 86400.0,
    "user_profile": {
      "enable": true,
      "expire_days": 14
    },
    "group_profile": {
      "enable": true,
      "expire_days": 14
    },
    "event_log": {
      "enable": true,
      "expire_days": 14
    },
    "public_knowledge": {
      "enable": true,
      "expire_days": 14
    }
  }
}
