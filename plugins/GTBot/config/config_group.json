{
  "default": {
    "chat_model": {
      "model": "ds/chat",
      "maximum_number_of_incoming_messages": 40,
      "max_message_length": 200,
      "behavioral_prompt": "行为提示词/默认_优化版.txt",
      "character_prompt": "角色提示词/天天2_优化版.md",
      "memory": {
        "notepad_max_entries": 15,
        "notepad_retention_seconds": 600
      },
      "max_concurrent_responses_per_group": 1,
      "max_total_concurrent_responses": 5,
      "rejection_emoji_id": 10060,
      "max_tool_calls_per_turn": 20,
      "recursion_limit": 50,
      "processing_emoji_id": 10024,
      "completion_emoji_id": 127881,
      "api_timeout_sec": 60,
      "continuation": {
        "enabled": true,
        "window_seconds":  30,
        "debounce_seconds":  3,
        "scope": "all",
        "analyzer_model": "aly/qwen-turbo",
        "analyzer_parameters": {
          "enable_thinking": false,
          "stream": false
        },
        "max_pending_messages": 8,
        "max_accumulated_messages": 12,
        "pre_history_messages": 6,
        "max_analyzer_context_messages": 40
      }
    },
    "user_profile": {
      "max_descriptions": 10,
      "max_description_char_length": 500
    },
    "message_format_placeholder": "[[$time_M]-[$time_d] [$time_h]:[$time_m]:[$time_s]] [$user_name]([$user_id], [$message_id]):[$message]"
  }
}
