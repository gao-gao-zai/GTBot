# ======================
# 主配置文件说明
# ======================

# 默认配置分区


# 提示词目录路径（用于存放各种提示词模板）
prompt_dir = "prompts"

# ----------------------
# 主对话AI配置
# ----------------------
[main_ai]
# 使用的AI模型标识
# main_model = "oneapi/glm-4.5-air"

main_model = "oneapi/gemini-2.0-flash"
# main_model = "volcengine/doubao-seed-1-6-flash"
# 聊天模型是否为推理模型
is_reasoning_model = false
# 生成文本的随机性控制（0.0-2.0，值越高输出越随机）
temperature = 1.0
# 输出格式提示词文件路径（控制AI响应格式）
main_output_prompt = "输出格式提示词/default.txt"
# main_output_prompt = "输出格式提示词/reasoning_default.txt"
# 角色扮演提示词文件路径（定义AI的说话风格和角色）
main_character_prompt = "角色提示词/天天.txt"

# ----------------------
# 图像识别配置
# ----------------------
[image_recognition]
# 是否启用图像识别功能
enable = true
# 图像识别使用的AI模型
ai_model = "oneapi/qwen2.5-vl-32b-instruct"
# 识图模型是否为推理模型
is_reasoning_model = false
# 图像识别提示词文件路径
prompt_path = "识图模型提示词/default.txt"
# 最大并发处理任务数
max_concurrent_tasks = 2
# 单次会话最多调用API处理图片数量
max_api_calls_per_recognition = 2
# 支持的最大单张图片大小（MB）
max_image_size_mb = 0.2
# 图像缓存数据库路径
cache_db_path = "data/image_cache.db"
# 图像处理中的表情ID（显示处理状态）
processing_emoji_id = 30
# 最多允许失败的次数，超过该次数后图像将被跳过
max_recognition_failures = 2
# 图像失败计数重置的时间（以秒为单位）
failure_reset_window_seconds = 3600
# ----------------------
# 表情响应配置. -1表示关闭. 详见https://bot.q.qq.com/wiki/develop/api-v2/openapi/emoji/model.html
# ----------------------
[emoji_response]
# 是否启用表情回应功能
enable_emoji_response = true
# 消息处理中显示的表情ID
processing_emoji_id = 10024
# 消息处理成功显示的表情ID
processing_success_emoji_id = 320
# 消息被拒绝时显示的表情ID
processing_rejected_emoji_id = 10060
# 处理完成后是否移除进行中表情
remove_processing_emoji_after_complete = true

# ----------------------
# 消息处理配置
# ----------------------
[message_handling]
# 聊天记录数据库路径
chat_record_db_path = "data/data.db"
# 是否启用流式响应（逐段发送AI回复）
enable_streaming = true
# 历史记录中保留的最大用户消息数量
max_chat_history_limit = 15
# 单条消息的最大显示长度（超出部分会截断）
max_single_message_length = 300
# 历史记录中额外保留的AI消息数量
max_extra_ai_messages = 10
# 历史记录中额外保留的QQ系统消息数量
max_extra_qq_system_messages = 5
# 是否将机器人的名称替换为"我"（中文语境更自然）
replace_my_name_with_me = true
# 流式响应时消息发送的最小间隔时间（秒）
min_send_interval = 0.4
# 发送间隔随机浮动范围（增加自然感）
send_interval_random_range = 0.2
# QQ系统消息的特殊用户ID
QQ_system_message_id = -1
# QQ系统消息的显示名称
QQ_system_name = "QQ_system"
# 将聊群元数据注入给AI
inject_group_metadata = true
# 将有关的用户元数据注入给AI  
inject_user_metadata = true

# ----------------------
# 检索增强生成配置
# ----------------------
[Retrieval_Augmented_Generation]
# # 是否启用检索增强生成功能
# enable = true
# # ChromaDB服务地址
# chroma_service_url = "http://127.0.0.1:8000"
# # ollama服务地址
# ollama_service_url = "http://127.0.0.1:11434"
# # ollama的嵌入模型
# embedding_model = "quentinz/bge-base-zh-v1.5:latest"
# # ollama的重排模型
# reranker_model = "linux6200/bge-reranker-v2-m3"

# 是否启用检索增强生成功能
enable = true
# ChromaDB服务地址
chroma_service_url = "http://127.0.0.1:30004"
# ChromaDB租户名
tenant = "default_tenant"
# 要使用的嵌入模型
embedding_model = "ollama/bge-base-zh-v1.5"
# 要使用的重排模型
reranker_model = "ollama/bge-reranker-v2-m3"
# 记录聊天记录
enable_record_chat_history = true
# 自动检索聊天记录给聊天AI
enable_chat_history_retrieval = true
# 启用知识库功能
enable_knowledge_base = true
# 自动检索知识库条目给聊天AI
enable_knowledge_base_retrieval = true
# 知识库管理AI  (语言模型)
knowledge_base_management_ai = "oneapi/gemini-2.5-flash-lite"
# 知识库管理员提示词文件路径
knowledge_base_management_prompt_path = "知识库管理员提示词.txt"